# ==========================================================
# Personal Leak Detector — PRODUCTION .env
# Nusxa oling:  cp .env.prod.example .env.prod
# Keyin CHANGE_ME larni to'ldiring. Bu faylni GIT'ga QO'SHMANG.
# ==========================================================

# --- Database (docker tarmog'idagi postgres) ---
POSTGRES_USER=pld_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=pld_db
DATABASE_URL=postgresql://pld_user:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/pld_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Security ---
# SECRET_KEY yaratish:        openssl rand -hex 32
# ENCRYPTION_KEY (32 bayt):   openssl rand -hex 16   (32 ta hex belgi = 16 bayt) yoki 32 belgili matn
SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_KEY

# --- Domen / Frontend ---
FRONTEND_URL=https://myleakdetector.org

# --- Gmail OAuth (Google Cloud Console'dan) ---
# Redirect URI ni Google Console'ga AYNAN shu ko'rinishda qo'shing:
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://myleakdetector.org/api/v1/oauth/gmail/callback

# --- Fayl yuklash ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
