    "changeEmail": "Email almashtirish",
    "changeEmailDesc": "Hisobingiz bilan bog'langan email manzilini o'zgartiring.",
    "changeEmailButton": "Emailni o'zgartirish",
    "lastSync": "Oxirgi sinxronlash",
    "loginRequired": "Gmail hisobini ulash uchun avval login qiling",
    "confirmAnalyze": "\"{{email}}\" Gmail hisobini tahlil qilishni boshlashni xohlaysizmi?",
    "scanNotFound": "Tahlil topilmadi yoki allaqachon tugagan.",
    "confirmCancelScan": "Tahlilni bekor qilishni xohlaysizmi?",
    "cancelScanError": "Tahlilni bekor qilishda xatolik",
    "modifyScopeNoticeTitle": "Muhim: Xabarlarni o'chirish va spam sifatida belgilash uchun",
    "modifyScopeNoticeBodyHtml": "Agar siz Gmail xabarlarini o'chirish yoki spam sifatida belgilash funksiyalaridan foydalanmoqchi bo'lsangiz, Gmail hisobingizni <strong>qayta ulashingiz</strong> kerak. Bu yangi <code class='bg-orange-100 px-1 rounded'>gmail.modify</code> scope'ini qo'shadi.",
    "modifyScopeNoticeHowToHtml": "<strong>Qanday qilish:</strong> Quyidagi ro'yxatdan Gmail hisobingizni o'chirib tashlang, keyin \"Gmail Hisobini Ulash (OAuth)\" tugmasini bosing va qayta ulang.",
    "gmailGuideTitle": "Gmail Hisobini Ulash Qo'llanmasi",
    "gmailGuideCardTitle": "Gmail Hisobini Ulash (Ixtiyoriy)",
    "gmailGuideHtml": "<p><strong>Maqsad:</strong> Gmail xabarlarida shaxsiy ma'lumotlaringiz oqib ketganini aniqlash</p><p class='mt-3'><strong>📋 Google Cloud Console'da Credentials olish (0 dan boshlab):</strong></p><ol class='list-decimal list-inside ml-2 space-y-2'><li><strong>Google Cloud Console'ga kirish:</strong><ul class='list-disc list-inside ml-4 mt-1 space-y-1'><li>Google Cloud Console: <a href='https://console.cloud.google.com/' target='_blank' rel='noopener noreferrer' class='text-blue-600 underline font-medium'>https://console.cloud.google.com/</a></li><li>Google hisobingiz bilan login qiling</li></ul></li><li><strong>Gmail API'ni yoqish:</strong><ul class='list-disc list-inside ml-4 mt-1 space-y-1'><li>APIs &amp; Services → Library → Gmail API → ENABLE</li><li>2–3 daqiqa kuting</li></ul></li><li><strong>OAuth consent screen:</strong><ul class='list-disc list-inside ml-4 mt-1 space-y-1'><li>User type: External</li><li>Scopes: gmail.readonly, <b>gmail.modify</b>, userinfo.email, userinfo.profile</li><li>Testing bo'lsa: Test users qo'shing</li></ul></li><li><strong>Credentials yaratish:</strong><ul class='list-disc list-inside ml-4 mt-1 space-y-1'><li>APIs &amp; Services → Credentials → OAuth client ID (Web application)</li><li>Redirect URI: <code class='bg-pink-100 px-1 rounded text-xs'>http://localhost:8000/api/v1/oauth/gmail/callback</code></li></ul></li><li><strong>credentials.json yuklab oling</strong> va <code class='bg-pink-100 px-1 rounded'>credentials.json</code> deb nomlang</li></ol><p class='mt-3'><strong>📤 credentials.json yuklash:</strong></p><ol class='list-decimal list-inside ml-2 space-y-1'><li>Sozlamalar → Credentials.json Yuklash</li><li>Faylni tanlab yuklang</li><li>So'ng \"Gmail Hisobini Ulash (OAuth)\" ni bosing</li></ol><p class='mt-3'><strong>🔍 Gmail tahlil:</strong></p><ol class='list-decimal list-inside ml-2 space-y-1'><li>Ulangan hisob yonidagi 🔍 tugmani bosing</li><li>Natijalar: <b>Topilmalar</b> va <b>Skanlar</b> sahifalarida</li></ol><p class='mt-2'><strong>Muammo yechish:</strong></p><ul class='list-disc list-inside ml-2 space-y-1'><li><b>accessNotConfigured</b>: Gmail API yoqilmagan bo'lishi mumkin</li><li><b>redirect_uri_mismatch</b>: redirect URI ni console'ga qo'shing</li><li><b>403 access_denied</b>: Testing bo'lsa test user qo'shing yoki Production'ga chiqaring</li></ul>",
